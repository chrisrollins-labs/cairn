# Copy to .env.local and fill locally. Placeholder NAMES only live here — never
# a real value. This file is committed; .env.local is gitignored. A unit test
# asserts every line here is a NAME=<placeholder>, so a real secret can't be
# pasted in by accident. (See SECURITY.md and tests/env-example.test.ts.)

# --- AI gateway --------------------------------------------------------------
# The single model egress (ADR-004). Any endpoint that speaks the OpenAI
# /chat/completions contract works: OpenAI, OpenRouter, or a local gateway.
AI_API_BASE_URL=https://api.example-provider.com/v1
AI_API_KEY=your-api-key-here
AI_DEFAULT_MODEL=example/model-name

# Zero-data-retention: when true, the gateway only routes to endpoints that
# contractually do not retain prompt/response data (ADR-004). Default true.
AI_ZERO_DATA_RETENTION=true

# --- Storage -----------------------------------------------------------------
# Store adapter: "memory" (default, zero infrastructure) or "postgres".
# The whole app and test suite run with "memory"; Postgres is one seam away.
CAIRN_STORE=memory

# Only read when CAIRN_STORE=postgres. Local dev value shown; use RLS-scoped
# connections in production (see docs/architecture/tenancy-and-rls.md).
DATABASE_URL=postgres://cairn:cairn@localhost:5432/cairn

# --- Site --------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000
