  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.10",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.17.0",
    "eslint-config-next": "16.2.10",
    "tailwindcss": "^4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
