{
  "name": "cairn",
  "version": "0.1.0",
  "private": true,
  "description": "Reference implementation for review-gated, tamper-evident personal records: AI drafts, a human approves, and every change joins a verifiable hash chain.",
  "author": "Chris Rollins <chrisrollins360@gmail.com> (https://rollinsdigital.com)",
  "license": "MIT",
  "homepage": "https://rollinsdigital.com/projects/cairn",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrisrollins-labs/cairn.git"
  },
  "bugs": {
    "url": "https://github.com/chrisrollins-labs/cairn/issues"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:rls": "node scripts/check-rls-coverage.mjs",
    "check:migrations": "node scripts/check-migration-order.mjs",
    "db:migrate": "tsx scripts/migrate.ts"
  },
  "dependencies": {
    "next": "16.2.10",
